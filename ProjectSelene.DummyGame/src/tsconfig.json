{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noImplicitAny": false,
    "target": "ES2020",
    "lib": ["ES2018", "DOM"],
    "sourceMap": true,
    "outDir": "../cache",
    "composite": true
  },
  "include": ["./**/*", "tsconfig.json"],
  "exclude": [
    "node_modules"
  ]
}
